{
	"$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
	"files": {
		"includes": ["src/**/*.ts", "src/**/*.svelte"]
	},
	"html": {
		"experimentalFullSupportEnabled": true
	},
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"rules": {
			"recommended": true
		}
	}
}
